# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-countries
# Load Order: 90 (loaded after all defaults, overrides earlier files)
#
# This file contains configuration specific to this project that differs from
# the shared defaults. Any variable set here takes precedence over values in
# 00-core.env through 20-workflows.env.
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION OVERRIDES
# ================================================================================================

# Secondary Go version for compatibility testing
GO_SECONDARY_VERSION=1.22.x

# ================================================================================================
# 📊 COVERAGE OVERRIDES
# ================================================================================================

# Coverage Report Provider (codecov for this project)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (matches codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/,docs/
